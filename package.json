{
	"version": "0.25.1",
	"name": "@absolutejs/auth",
	"description": "An authorization library for absolutejs",
	"repository": {
		"type": "git",
		"url": "https://github.com/absolutejs/absolute-auth.git"
	},
	"main": "./dist/index.js",
	"license": "CC BY-NC 4.0",
	"author": "Alex Kahn",
	"scripts": {
		"build": "rm -rf dist && bun build src/index.ts src/ui/index.ts --outdir dist --sourcemap --target=bun --external elysia && tsc --emitDeclarationOnly --project tsconfig.json",
		"test": "echo \"Error: no test specified\" && exit 1",
		"format": "prettier --write \"./**/*.{js,jsx,ts,tsx,css,json}\"",
		"lint": "eslint ./src ./eslint.config.mjs",
		"typecheck": "bun run tsc --noEmit",
		"release": "bun run format && bun run build && bun publish"
	},
	"keywords": [
		"authorization",
		"authentication",
		"absolutejs",
		"elysia",
		"oauth"
	],
	"types": "./dist/index.d.ts",
	"peerDependencies": {
		"elysia": ">= 1.4.26"
	},
	"dependencies": {
		"@absolutejs/linked-providers": "0.0.2",
		"citra": "0.25.11",
		"@neondatabase/serverless": "1.0.0",
		"drizzle-orm": "0.41.0"
	},
	"devDependencies": {
		"@stylistic/eslint-plugin-ts": "4.2.0",
		"@types/bun": "1.2.9",
		"elysia": "1.4.26",
		"eslint": "9.26.0",
		"eslint-plugin-absolute": "0.0.3",
		"eslint-plugin-import": "2.31.0",
		"eslint-plugin-promise": "7.2.1",
		"eslint-plugin-security": "3.0.1",
		"prettier": "3.5.3",
		"typescript": "5.8.3",
		"typescript-eslint": "8.32.0"
	},
	"module": "./dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./ui": {
			"import": "./dist/ui/index.js",
			"types": "./dist/ui/index.d.ts"
		}
	},
	"type": "module",
	"files": [
		"dist",
		"README.md"
	],
	"typesVersions": {
		"*": {
			"*": [
				"dist/index.d.ts"
			]
		}
	}
}
